# Crystal Castle Environment Variables

# Node environment
NODE_ENV=main

# ========== REQUIRED ==========
# Supabase
SUPABASE_URL : your_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY : 
# Groq AI
GROQ_API_KEY = your_key_here

# ========== OPTIONAL ==========
# Fallback AI
GEMINI_API_KEY = ""

# Video Generation
FAL_KEY=fal_your_key_here
MAGIC_HOUR_API_KEY = ""

# Supabase Admin (server-side only)
SUPABASE_SERVICE_ROLE_KEY= = your_key_here

# ========== DEVELOPMENT ONLY ==========
NEXT_PUBLIC_USE_MOCK=true
